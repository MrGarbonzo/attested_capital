# ═══════════════════════════════════════════════════════════════
# Guardian Network — Environment Variables
# These are overridden by sealed config if present.
# Copy to .env and fill in: cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Required (or provided via sealed config) ──────────────────
GUARDIAN_TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=
SOLANA_RPC_URL=https://api.devnet.solana.com
REGISTRY_PROGRAM_ID=

# ── Guardian Identity ─────────────────────────────────────────
GUARDIAN_ADDRESS=guardian-1
# External URL agents use to reach this guardian
GUARDIAN_EXTERNAL_ENDPOINT=http://YOUR_VM_IP:3100
IS_SENTRY=true

# ── Optional ──────────────────────────────────────────────────
# VAULT_KEY=
# FUND_MANAGER_ENDPOINT=http://AGENT_VM_IP:8080
# APPROVED_MEASUREMENTS=
# GUARDIAN_OWNER_TELEGRAM_ID=
# SEED_RPCS=solana=https://api.devnet.solana.com
