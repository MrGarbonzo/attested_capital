# ═══════════════════════════════════════════════════════════════
# Panthers Fund Agent — Environment Variables
# These are overridden by sealed config if present.
# Copy to .env and fill in: cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Required (or provided via sealed config) ──────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=
SECRET_AI_API_KEY=
SOLANA_RPC_URL=https://api.devnet.solana.com
REGISTRY_PROGRAM_ID=

# ── Agent Identity ────────────────────────────────────────────
# External hostname/IP for registry self-registration
AGENT_EXTERNAL_HOST=YOUR_VM_IP

# ── Optional ──────────────────────────────────────────────────
# SECRET_AI_BASE_URL=https://secretai-rytn.scrtlabs.com:21434/v1
# SECRET_AI_MODEL=llama3.3:70b
# SENTIMENT_AI_MODEL=deepseek-r1:70b
