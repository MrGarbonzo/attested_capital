# ── Secret AI (required) ────────────────────────────────────────
SECRET_AI_API_KEY=your-secret-ai-api-key
SECRET_AI_BASE_URL=https://secretai-rytn.scrtlabs.com:21434/v1
SECRET_AI_MODEL=llama3.3:70b

# ── Telegram (required) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# ── Telegram (optional) ────────────────────────────────────────
# Comma-separated Telegram user IDs allowed to use the bot (empty = all)
# TELEGRAM_ALLOWED_USERS=123456789,987654321
# Chat ID where cron alerts are sent
# TELEGRAM_ALERT_CHAT_ID=123456789

# ── Solana (required) ─────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── Optional chain RPCs (have defaults) ───────────────────────
# SECRET_LCD_URL=https://lcd.mainnet.secretsaturn.net
# ETHEREUM_RPC_URL=https://eth.llamarpc.com
# BASE_RPC_URL=https://mainnet.base.org

# ── Jupiter (optional) ────────────────────────────────────────
# JUPITER_API_KEY=

# ── Database (optional — has default) ─────────────────────────
# PANTHERS_DB_PATH=/data/panthers.db
