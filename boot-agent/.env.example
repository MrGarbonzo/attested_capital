# ═══════════════════════════════════════════════════════════════
# Boot Agent — Environment Variables
# One-shot bootstrapper: deploys Solana registry + agent VM.
# Guardians are deployed separately after agent registers on-chain.
# Copy to .env and fill in: cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_AGENT_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=

# ── Secret AI ────────────────────────────────────────────────
SECRET_AI_API_KEY=

# ── Solana ───────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
JUPITER_API_KEY=

# ── VM Deployment ─────────────────────────────────────────────
BOOT_IMAGE_TAG=main-abc1234
AGENT_IMAGE_TAG=main-abc1234
# VM_SIZE=small                 # small | medium | large (default: small)

# ── Optional ─────────────────────────────────────────────────
# REGISTRY_PROGRAM_ID=          # If set, skips deploy and verifies this program
# APPROVED_MEASUREMENTS=        # Comma-separated TEE measurement hashes
# MOCK_NFT=true                 # DB-only NFTs, no on-chain minting (for testnet)
# DEV_MODE=true                 # Deploy VMs with SSH access (secretvm -E dev)
