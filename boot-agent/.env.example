# ═══════════════════════════════════════════════════════════════
# Boot Agent — Environment Variables
# Runs once to generate sealed configs for agent + guardian.
# Copy to .env and fill in: cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_AGENT_BOT_TOKEN=
TELEGRAM_GUARDIAN_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=
TELEGRAM_ALERT_CHAT_ID=
TELEGRAM_ALLOWED_USERS=

# ── Secret AI ────────────────────────────────────────────────
SECRET_AI_API_KEY=

# ── Solana ───────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
JUPITER_API_KEY=

# ── Agent ────────────────────────────────────────────────────
AGENT_EXTERNAL_HOST=

# ── VM Deployment ─────────────────────────────────────────────
AGENT_IMAGE_TAG=main-abc1234
GUARDIAN_IMAGE_TAG=main-abc1234
# VM_SIZE=small                 # small | medium | large (default: small)

# ── Optional ─────────────────────────────────────────────────
# REGISTRY_PROGRAM_ID=          # If set, skips deploy and verifies this program
# APPROVED_MEASUREMENTS=        # Comma-separated TEE measurement hashes
